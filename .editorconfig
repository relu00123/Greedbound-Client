# Unreal Engine coding style
root = true

[*.{h,cpp}]
charset = utf-8-bom        # UTF-8 with BOM
indent_style = space       # 들여쓰기는 Space
indent_size = 4            # 4칸 들여쓰기
tab_width = 4              # Tab을 눌렀을 때도 Space 4개로 변환
end_of_line = lf           # LF (Unix 스타일 개행, UE는 기본적으로 LF 권장)
insert_final_newline = true # 파일 끝에 개행 삽입

# Build.cs, Target.cs 같은 C# 파일도 동일 규칙 적용
[*.cs]
charset = utf-8-bom
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
insert_final_newline = true

# Config/INI 파일
[*.ini]
charset = utf-8-bom
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true


# Plugin, Project 파일
[*.{uplugin,uproject}]
charset = utf-8-bom
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true

# JSON (가끔 쓰는 설정)
[*.json]
charset = utf-8-bom
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true